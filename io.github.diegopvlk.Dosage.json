{
	"id": "io.github.diegopvlk.Dosage",
	"runtime": "org.gnome.Platform",
	"runtime-version": "50",
	"sdk": "org.gnome.Sdk",
	"command": "io.github.diegopvlk.Dosage",
	"finish-args": [
		"--share=ipc",
		"--socket=fallback-x11",
		"--device=dri",
		"--socket=wayland",
		"--system-talk-name=org.freedesktop.login1",
		"--socket=pulseaudio"
	],
	"cleanup": [
		"/include",
		"/lib/pkgconfig",
		"/share/gir-1.0"
	],
	"modules": [
		{
			"name": "libportal",
			"buildsystem": "meson",
			"config-opts": ["-Ddocs=false", "-Dvapi=false"],
			"sources": [
				{
					"type": "git",
					"url": "https://github.com/flatpak/libportal",
					"tag": "0.9.1",
					"commit": "8f5dc8d192f6e31dafe69e35219e3b707bde71ce"
				}
			]
		},
		{
			"name": "dosage",
			"buildsystem": "meson",
			"builddir": true,
			"sources": [
				{
					"type": "git",
					"url": "https://github.com/diegopvlk/Dosage",
					"tag": "v2.1.6",
					"commit": "90a5fc17a2e73421d8c5c39ce6cb5ed7f5e374c7"
				}
			]
		}
	]
}

